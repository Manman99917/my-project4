.calendar-page {
  padding: 20rpx 24rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f7ff 0%, #f5f5f5 100%);
}

.streak-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 30rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(135deg, #fff8e1 0%, #ffecb3 100%);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(255, 193, 7, 0.2);
}

.streak-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.streak-text {
  font-size: 26rpx;
  color: #6d4c00;
}

.streak-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #e65100;
  margin-left: 16rpx;
  padding: 4rpx 16rpx;
  background-color: rgba(255, 255, 255, 0.7);
  border-radius: 8rpx;
}

.month-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0 40rpx;
}

.month-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #2c3e50;
  margin: 0 50rpx;
}

.arrow {
  font-size: 28rpx;
  padding: 16rpx 24rpx;
  color: #666;
  background-color: #fff;
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.weekday-row {
  display: flex;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
}

.weekday-cell {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
}

.days-grid {
  display: flex;
  flex-wrap: wrap;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 16rpx 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.3s ease, opacity 0.3s ease;
}

.days-grid.slide-left {
  animation: slideLeft 0.3s ease;
}

.days-grid.slide-right {
  animation: slideRight 0.3s ease;
}

@keyframes slideLeft {
  0% { transform: translateX(60rpx); opacity: 0; }
  100% { transform: translateX(0); opacity: 1; }
}

@keyframes slideRight {
  0% { transform: translateX(-60rpx); opacity: 0; }
  100% { transform: translateX(0); opacity: 1; }
}

.day-cell {
  width: 14.28%;
  min-height: 130rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-top: 16rpx;
  box-sizing: border-box;
  position: relative;
  border-radius: 12rpx;
  transition: background-color 0.2s;
}

.day-cell.empty {
  background: transparent;
}

.day-cell.selected {
  background-color: #e3f2fd;
}

.day-number {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.day-icons {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-top: 8rpx;
}

.day-icon {
  font-size: 22rpx;
}

.day-more {
  font-size: 18rpx;
  color: #999;
  font-weight: bold;
}

.detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.detail-panel {
  width: 620rpx;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 44rpx 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 36rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #2c3e50;
}

.detail-close {
  font-size: 36rpx;
  color: #bbb;
  padding: 10rpx;
}

.detail-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: #fafafa;
  border-radius: 16rpx;
  border-left: 6rpx solid #7eb8b8;
}

.detail-item:nth-child(odd) {
  border-left-color: #c4a882;
}

.detail-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.detail-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.detail-time {
  font-size: 24rpx;
  color: #999;
  margin-left: auto;
}

.detail-delete {
  font-size: 22rpx;
  color: #e74c3c;
  margin-left: 20rpx;
  padding: 8rpx 16rpx;
  border: 1rpx solid #e74c3c;
  border-radius: 8rpx;
}

.detail-empty {
  text-align: center;
  padding: 50rpx;
  color: #bbb;
  font-size: 28rpx;
}

.bottom-quote {
  margin-top: 40rpx;
  text-align: center;
  padding: 30rpx 20rpx;
}

.quote-text {
  font-size: 26rpx;
  color: #aaa;
  font-style: italic;
}
